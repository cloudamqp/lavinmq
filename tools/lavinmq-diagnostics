#!/usr/bin/env python3
"""
lavinmq-diagnostics top — CPU hot functions for LavinMQ

Two BPF programs run simultaneously:

  1. perf CPU clock sampler (99 Hz)
     Captures: user stack, kernel stack, TID, CPU core, OS thread name.

  2. uprobe on Thread#current_fiber=(fiber : Fiber)
     Called by the execution-context scheduler on every fiber context switch.
     The incoming Fiber is the second argument (rsi); we read its @name field
     and write it into a tid_to_fiber map keyed by TID.
     Combined with (1) this gives exact TID → queue/connection attribution.

Crystal fiber names in LavinMQ identify the workload directly:
  "Consumer vhost=default queue=orders"
  "Queue#message_expire_loop default/orders"
  "Shovel name=cross-dc vhost=default"

The @name field offset in Crystal::Fiber is extracted from DWARF at startup.
Pass --fiber-name-offset N to override when the binary lacks debug info.

Requires: python3-bpfcc (Debian/Ubuntu) or bcc-tools (RHEL/Fedora)
          CAP_BPF + CAP_PERFMON, or kernel.perf_event_paranoid <= 1
          LavinMQ built with debug info (make bin/lavinmq CRYSTAL_FLAGS=--debug)
"""

import argparse
import os
import re
import subprocess
import sys
import time
from collections import defaultdict

try:
    from bcc import BPF, PerfType, PerfSWConfig
except ImportError:
    sys.exit(
        "Error: python3-bpfcc is not installed.\n"
        "  Debian/Ubuntu: apt install python3-bpfcc\n"
        "  RHEL/Fedora:   dnf install bcc-tools"
    )

# Crystal String object layout (Crystal 1.x):
#   +0  @bytesize : Int32  (4 bytes)
#   +4  @length   : Int32  (Unicode codepoint count, 4 bytes)
#   +8  content            (null-terminated byte array)
CRYSTAL_STRING_CONTENT_OFFSET = 8


BPF_PROGRAM = r"""
#include <uapi/linux/ptrace.h>
#include <linux/sched.h>

#define FIBER_NAME_LEN 64

/* ── Shared maps ──────────────────────────────────────────────────────────── */

struct key_t {
    u32 pid;
    u32 tid;
    u32 cpu;
    int user_stack_id;
    char comm[TASK_COMM_LEN];
};

/* BPF_HASH requires a named struct as value type — plain arrays not allowed. */
struct fiber_name_t {
    char name[FIBER_NAME_LEN];
};

BPF_STACK_TRACE(user_stacks, 16384);
BPF_HASH(counts, struct key_t, u64, 16384);

/* Fiber uprobe map: tid → current Crystal fiber name */
BPF_HASH(tid_to_fiber, u32, struct fiber_name_t, 1024);

/* Debug counters: [0]=resume fires, [1]=getter fires */
BPF_ARRAY(uprobe_hits, u64, 2);

/* ── CPU clock sampler ────────────────────────────────────────────────────── */

int sample_stack(struct bpf_perf_event_data *ctx) {
    u64 id  = bpf_get_current_pid_tgid();
    u32 pid = id >> 32;
    u32 tid = (u32)id;

    if (TARGET_PID && pid != (u32)TARGET_PID)
        return 0;

    struct key_t key = {};
    key.pid             = pid;
    key.tid             = tid;
    key.cpu             = bpf_get_smp_processor_id();
    key.user_stack_id   = user_stacks.get_stackid(ctx, BPF_F_USER_STACK | BPF_F_REUSE_STACKID);
    bpf_get_current_comm(&key.comm, sizeof(key.comm));

    counts.increment(key);
    return 0;
}

/* ── Shared helper: record fiber name for current TID ─────────────────────── */

static __always_inline void record_fiber(u32 pid, u32 tid, u64 fiber) {
    if (TARGET_PID && pid != (u32)TARGET_PID)
        return;
    if (!fiber)
        return;

    u64 name_ptr = 0;
    bpf_probe_read_user(&name_ptr, sizeof(name_ptr),
                        (void *)(fiber + FIBER_NAME_OFFSET));

    struct fiber_name_t fname = {};
    if (name_ptr) {
        /* Crystal String: +0 bytesize(i32) +4 length(i32) +8 content(bytes) */
        bpf_probe_read_user_str(fname.name, FIBER_NAME_LEN,
                                (void *)(name_ptr + STRING_CONTENT_OFFSET));
    }

    tid_to_fiber.update(&tid, &fname);
}

/* ── uprobe: Fiber::ExecutionContext::Parallel::Scheduler#resume(fiber) ──────── */
/*                                                                              */
/* Called by the parallel scheduler each time it resumes a fiber. 148 bytes,   */
/* not inlined. The target Fiber is passed directly:                            */
/*   rdi = self (Scheduler), rsi = fiber being resumed                          */

int on_fiber_resume(struct pt_regs *ctx) {
    u64 id = bpf_get_current_pid_tgid();
    u32 slot = 0;
    uprobe_hits.increment(slot);
    record_fiber(id >> 32, (u32)id, (u64)PT_REGS_PARM2(ctx));
    return 0;
}

/* ── uretprobe: Thread#current_fiber (getter) ─────────────────────────────── */
/*                                                                              */
/* Fires whenever the runtime reads the current fiber (scheduling, GC roots,   */
/* I/O checks). Captures long-lived fibers that never switch during the window. */
/*   rax = return value = current Fiber*                                        */

int on_fiber_get(struct pt_regs *ctx) {
    u64 id = bpf_get_current_pid_tgid();
    u32 slot = 1;
    uprobe_hits.increment(slot);
    record_fiber(id >> 32, (u32)id, (u64)PT_REGS_RC(ctx));
    return 0;
}
"""

BOLD = "\033[1m"
RESET = "\033[0m"
DIM  = "\033[2m"
CYAN = "\033[36m"


def trunc(s, n):
    return s if len(s) <= n else s[:n - 3] + "..."


def bar(pct, width=20):
    return "█" * int(pct / 100 * width)


def section(title):
    pad = "─" * max(0, 74 - len(title))
    print(f"\n{BOLD}{CYAN}── {title} {pad}{RESET}")


# ── Binary / symbol helpers ───────────────────────────────────────────────────

def binary_for_pid(pid):
    return os.readlink(f"/proc/{pid}/exe")


def find_sym(binary, substring):
    """Return (address, mangled_name) of the shortest symbol containing substring.

    Tries nm --defined-only first (fast, works on full binaries).  Falls back to
    readelf -Ws for split-debug .dbg files where objcopy --only-keep-debug marks
    code sections SHT_NOBITS, causing nm to report them as 'b' not 'T'.
    """
    try:
        out = subprocess.check_output(
            ["nm", "--defined-only", "-p", binary],
            stderr=subprocess.DEVNULL,
        ).decode(errors="replace")
        candidates = []
        for line in out.splitlines():
            parts = line.split(None, 2)
            if len(parts) < 3 or parts[1] not in ("T", "t"):
                continue
            if substring in parts[2]:
                candidates.append((int(parts[0], 16), parts[2]))
        if candidates:
            candidates.sort(key=lambda x: len(x[1]))
            return candidates[0]
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    try:
        out = subprocess.check_output(
            ["readelf", "-Ws", binary],
            stderr=subprocess.DEVNULL,
        ).decode(errors="replace")
        candidates = []
        for line in out.splitlines():
            if "FUNC" not in line or substring not in line:
                continue
            parts = line.split()
            if len(parts) < 8:
                continue
            try:
                addr = int(parts[1], 16)
            except ValueError:
                continue
            name = parts[-1]
            if addr > 0 and substring in name:
                candidates.append((addr, name))
        if candidates:
            candidates.sort(key=lambda x: len(x[1]))
            return candidates[0]
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    return None, None


def find_syms(binary, *substrings):
    """Return all (address, name) pairs where the symbol contains ALL substrings."""
    results = []
    try:
        out = subprocess.check_output(
            ["readelf", "-Ws", binary],
            stderr=subprocess.DEVNULL,
        ).decode(errors="replace")
        for line in out.splitlines():
            if "FUNC" not in line:
                continue
            if not all(s in line for s in substrings):
                continue
            parts = line.split()
            if len(parts) < 8:
                continue
            try:
                addr = int(parts[1], 16)
            except ValueError:
                continue
            if addr > 0:
                results.append((addr, parts[-1]))
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return results


def get_build_id(path):
    """Return the GNU build-ID hex string for an ELF, or None."""
    try:
        out = subprocess.check_output(
            ["readelf", "-n", path], stderr=subprocess.DEVNULL,
        ).decode(errors="replace")
        m = re.search(r"Build ID:\s*([0-9a-f]+)", out)
        return m.group(1) if m else None
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def find_debug_binary(binary):
    """Locate the split debug file for binary, following standard Linux conventions.

    Checks in order:
      1. binary.debug / binary.dbg alongside the binary  (dev / install-dbg)
      2. /usr/lib/debug/<binary_path>.debug  (Debian dh_strip / RPM find-debuginfo)
      3. /usr/lib/debug/.build-id/xx/yyyyyy.debug  (build-ID symlink, both distros)

    Returns the path string, or None if not found.
    """
    for suffix in (".debug", ".dbg"):
        path = binary + suffix
        if os.path.exists(path):
            return path

    for suffix in (".debug", ".dbg"):
        path = f"/usr/lib/debug{binary}{suffix}"
        if os.path.exists(path):
            return path

    try:
        out = subprocess.check_output(
            ["readelf", "-n", binary],
            stderr=subprocess.DEVNULL,
        ).decode(errors="replace")
        m = re.search(r"Build ID:\s*([0-9a-f]{2})([0-9a-f]+)", out)
        if m:
            path = f"/usr/lib/debug/.build-id/{m.group(1)}/{m.group(2)}.debug"
            if os.path.exists(path):
                return path
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    return None


def find_fiber_name_offset(binary):
    """Parse DWARF debug info to find the byte offset of @name in Crystal::Fiber.

    Uses depth-aware parsing so that nested types inside Fiber (Fiber::Context,
    Fiber::Stack, etc.) don't reset the search state.
    Returns an int offset, or None if DWARF is unavailable or parsing fails.
    """
    try:
        proc = subprocess.Popen(
            ["readelf", "--debug-dump=info", binary],
            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
            text=True, bufsize=65536,
        )
    except FileNotFoundError:
        return None

    # fiber_depth: DWARF nesting depth of the Fiber class DIE, or None
    fiber_depth = None
    current_depth = 0
    pending_class = False  # True after DW_TAG_class/struct, waiting to check DW_AT_name
    at_name_member = False
    result = None

    try:
        for line in proc.stdout:
            # DIE header lines look like: " <depth><offset>: Abbrev Number: N (DW_TAG_foo)"
            die_m = re.match(r"\s*<(\d+)><[0-9a-f]+>:\s*Abbrev Number", line)
            if die_m:
                depth = int(die_m.group(1))
                current_depth = depth
                pending_class = False

                # Leaving Fiber class scope: sibling or ancestor DIE
                if fiber_depth is not None and depth <= fiber_depth:
                    fiber_depth = None
                    at_name_member = False

                if "DW_TAG_class_type" in line or "DW_TAG_structure_type" in line:
                    if fiber_depth is None:
                        pending_class = True
                elif "DW_TAG_member" in line and fiber_depth is not None:
                    at_name_member = False
                continue

            if "DW_AT_name" in line:
                if pending_class and re.search(r":\s*Fiber\s*$", line):
                    fiber_depth = current_depth
                    pending_class = False
                elif fiber_depth is not None and re.search(r":\s*@?name\s*$", line):
                    at_name_member = True

            if at_name_member and "DW_AT_data_member_location" in line:
                m = re.search(r":\s*(\d+)\s*$", line.strip())
                if not m:
                    m = re.search(r"DW_OP_plus_uconst:\s*(\d+)", line)
                if m:
                    result = int(m.group(1))
                    break
    finally:
        proc.kill()
        proc.wait()

    return result


# ── Process helpers ───────────────────────────────────────────────────────────

def find_pid(args):
    if args.pid:
        return args.pid

    if args.pidfile and os.path.exists(args.pidfile):
        try:
            return int(open(args.pidfile).read().strip())
        except (ValueError, OSError):
            pass

    try:
        out = subprocess.check_output(["pgrep", "-x", "lavinmq"], stderr=subprocess.DEVNULL)
        pids = out.decode().strip().split()
        if len(pids) == 1:
            return int(pids[0])
        if len(pids) > 1:
            sys.exit(
                f"Error: multiple lavinmq processes found: {', '.join(pids)}\n"
                "Use --pid to specify which one."
            )
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    sys.exit(
        "Error: lavinmq process not found.\n"
        "Is it running? Use --pid PID or --pidfile PATH to specify."
    )


def check_permissions():
    if os.geteuid() == 0:
        return
    try:
        paranoid = int(open("/proc/sys/kernel/perf_event_paranoid").read().strip())
    except (OSError, ValueError):
        sys.exit("Error: cannot read perf_event_paranoid. Run as root or grant CAP_BPF + CAP_PERFMON.")
    if paranoid > 1:
        sys.exit(
            f"Error: kernel.perf_event_paranoid={paranoid} (must be <= 1).\n"
            "Fix:  sudo sysctl -w kernel.perf_event_paranoid=1\n"
            "  or: run lavinmq-diagnostics as root."
        )


# ── BPF collection ────────────────────────────────────────────────────────────

def resolve_user_sym(b, addr, pid):
    raw = b.sym(addr, pid, show_module=False, show_offset=False)
    return raw.decode("utf-8", errors="replace").lstrip("*")



def collect(b, pid, duration, debug_bpf=False):
    b["counts"].clear()
    b["user_stacks"].clear()
    # tid_to_fiber is NOT cleared — it persists across windows and reflects
    # the most recently resumed fiber on each thread.

    deadline = time.monotonic() + duration
    while time.monotonic() < deadline:
        if not os.path.exists(f"/proc/{pid}"):
            sys.exit(f"\nProcess {pid} exited during sampling.")
        time.sleep(0.5)

    tid_fiber = {
        k.value: v.name.decode("utf-8", errors="replace").rstrip("\x00")
        for k, v in b["tid_to_fiber"].items()
    }

    debug_info = None
    if debug_bpf:
        debug_info = {
            "hits_resume": b["uprobe_hits"][0].value,
            "hits_getter": b["uprobe_hits"][1].value,
            "tid_fiber":   tid_fiber,
        }

    user_sym_counts = defaultdict(int)
    thread_info = defaultdict(lambda: {
        "total": 0,
        "syms":  defaultdict(int),
        "cpus":  defaultdict(int),
        "comm":  "",
        "fiber": None,  # None = uprobe hasn't fired for this TID yet
    })

    for key, count in b["counts"].items():
        n = count.value

        user_sym = "[unknown]"
        if key.user_stack_id >= 0:
            frames = list(b["user_stacks"].walk(key.user_stack_id))
            if frames:
                user_sym = resolve_user_sym(b, frames[0], pid)
        user_sym_counts[user_sym] += n

        t = thread_info[key.tid]
        t["total"] += n
        t["syms"][user_sym] += n
        t["cpus"][key.cpu] += n
        if not t["comm"]:
            t["comm"] = key.comm.decode("utf-8", errors="replace").rstrip("\x00")
        if t["fiber"] is None and key.tid in tid_fiber:
            t["fiber"] = tid_fiber[key.tid]  # "" means unnamed fiber (uprobe fired, @name is nil)

    return {
        "user":    user_sym_counts,
        "threads": thread_info,
        "debug":   debug_info,
    }


# ── Rendering ─────────────────────────────────────────────────────────────────

def render(data, pid, duration, freq, lines, has_uprobe):
    total = sum(data["user"].values()) or 1
    has_unknown = False

    print("\033[H\033[2J", end="")
    print(
        f"{BOLD}LavinMQ CPU Hot Functions{RESET}"
        f" — PID {pid}"
        f" — {duration}s @ {freq}Hz"
        f" — {total:,} samples"
    )

    # ── User-space hot functions ──────────────────────────────────────────────
    section("User-Space Hot Functions")
    print(f"  {'Rank':>4}  {'Function':<52}  {'Samples':>8}  {'CPU%':>5}  Bar")
    print("  " + "─" * 82)
    for i, (sym, count) in enumerate(
        sorted(data["user"].items(), key=lambda x: x[1], reverse=True)[:lines], 1
    ):
        pct = count / total * 100
        if sym == "[unknown]":
            has_unknown = True
        print(f"  {i:>4}  {trunc(sym, 52):<52}  {count:>8,}  {pct:>4.1f}%  {bar(pct)}")

    # ── Per-thread breakdown ──────────────────────────────────────────────────
    section("Per-Thread Breakdown")
    print(f"  {'TID':>8}  {'Fiber':<30}  {'Top Function':<28}  {'Samples':>8}  {'CPU%':>5}  {'CPUs':>6}")
    print("  " + "─" * 96)
    for tid, info in sorted(data["threads"].items(), key=lambda x: x[1]["total"], reverse=True)[:lines]:
        pct      = info["total"] / total * 100
        top_sym  = max(info["syms"], key=info["syms"].get) if info["syms"] else "?"
        cpu_list = ",".join(str(c) for c in sorted(info["cpus"]))

        if has_uprobe:
            if info["fiber"] is None:
                fiber = info["comm"] or "?"  # uprobe never fired for this TID
            elif info["fiber"]:
                fiber = info["fiber"]         # named fiber
            else:
                fiber = "(unnamed)"           # uprobe fired, @name is nil
        else:
            fiber = info["comm"] or "?"

        print(
            f"  {tid:>8}  {trunc(fiber, 30):<30}  {trunc(top_sym, 28):<28}"
            f"  {info['total']:>8,}  {pct:>4.1f}%  {cpu_list:>6}"
        )

    print(f"\n  {DIM}{time.strftime('%Y-%m-%d %H:%M:%S')}  |  Ctrl+C to exit{RESET}", end="")
    if has_unknown:
        print(
            f"\n\n  {DIM}Note: '[unknown]' symbols — install debug info:\n"
            f"    apt install lavinmq-dbg        # Debian/Ubuntu\n"
            f"    dnf install lavinmq-debuginfo  # RHEL/Fedora\n"
            f"    make bin/lavinmq.dbg           # from source{RESET}",
            end="",
        )
    print()


# ── Command ───────────────────────────────────────────────────────────────────

def cmd_top(args):
    check_permissions()
    pid = find_pid(args)

    if not os.path.exists(f"/proc/{pid}"):
        sys.exit(f"Error: no process with PID {pid}.")

    binary = binary_for_pid(pid)
    if args.verbose:
        print(f"[diag] binary: {binary}")

    # Resolve symbols — prefer the running binary's own symbol table (works when
    # built with debug info). Fall back to the split debug companion for stripped
    # binaries, but only if its build-ID matches the running binary.
    debug_binary = find_debug_binary(binary)

    # Search for any execution context resume variant (Parallel, Isolated,
    # MultiThreaded, etc.) — broaden to catch all scheduler implementations.
    resume_syms = find_syms(binary, "#resume<Fiber>")
    get_addr, get_name = find_sym(binary, "Thread#current_fiber:")

    if debug_binary:
        bin_id = get_build_id(binary)
        dbg_id = get_build_id(debug_binary)
        id_match = (bin_id is None or dbg_id is None or bin_id == dbg_id)
        if not id_match:
            print(
                f"WARNING: build-ID mismatch — debug file is stale!\n"
                f"  binary: {bin_id}\n"
                f"  debug:  {dbg_id}\n"
                f"  Addresses from {debug_binary} are WRONG for the running binary.\n"
                f"  Rebuild with:  make bin/lavinmq.dbg\n"
                f"  Fiber uprobe disabled until rebuilt."
            )
            debug_binary = None
        else:
            if not resume_syms:
                resume_syms = find_syms(debug_binary, "#resume<Fiber>")
            if not get_addr:
                get_addr, get_name = find_sym(debug_binary, "Thread#current_fiber:")

    if args.verbose:
        print(f"[diag] debug binary:        {debug_binary or 'not found'}")
        for addr, name in resume_syms:
            print(f"[diag] resume (switch):     0x{addr:x}  {name}")
        if not resume_syms:
            print(f"[diag] resume (switch):     not found")
        print(f"[diag] getter (long-lived): {f'0x{get_addr:x}  {get_name}' if get_addr else 'not found'}")

    # Resolve @name offset in Crystal::Fiber from DWARF.
    fiber_name_offset = args.fiber_name_offset
    if fiber_name_offset is None:
        fiber_name_offset = find_fiber_name_offset(binary)
        if fiber_name_offset is None and debug_binary:
            fiber_name_offset = find_fiber_name_offset(debug_binary)
    if args.verbose:
        src = "DWARF" if args.fiber_name_offset is None else "--fiber-name-offset"
        print(f"[diag] @name offset:       {fiber_name_offset}  (from {src})")

    if fiber_name_offset is None:
        print(
            f"{DIM}Warning: could not determine @name offset from DWARF.\n"
            f"  Fiber uprobe disabled. Options to enable:\n"
            f"    apt install lavinmq-dbg          # Debian/Ubuntu\n"
            f"    dnf install lavinmq-debuginfo    # RHEL/Fedora\n"
            f"    make bin/lavinmq.dbg             # from source\n"
            f"    --fiber-name-offset N            # manual override{RESET}"
        )

    has_uprobe = (bool(resume_syms) or get_addr is not None) and fiber_name_offset is not None

    prog = (
        BPF_PROGRAM
        .replace("TARGET_PID",            str(pid))
        .replace("FIBER_NAME_OFFSET",     str(fiber_name_offset or 0))
.replace("STRING_CONTENT_OFFSET", str(CRYSTAL_STRING_CONTENT_OFFSET))
    )
    b = BPF(text=prog)

    b.attach_perf_event(
        ev_type=PerfType.SOFTWARE,
        ev_config=PerfSWConfig.CPU_CLOCK,
        fn_name="sample_stack",
        sample_freq=args.freq,
    )

    if has_uprobe:
        for addr, name in resume_syms:
            try:
                b.attach_uprobe(name=binary, addr=addr, fn_name="on_fiber_resume")
            except Exception as e:
                print(f"WARNING: attach_uprobe failed for 0x{addr:x} ({name}): {e}")
        if get_addr:
            try:
                b.attach_uretprobe(name=binary, addr=get_addr, fn_name="on_fiber_get")
            except Exception as e:
                print(f"WARNING: attach_uretprobe failed for 0x{get_addr:x} ({get_name}): {e}")
        resume_lines = "\n".join(f"  resume:              {name}" for _, name in resume_syms) or "  resume:              not found"
        print(
            f"Fiber probes attached — @name offset {fiber_name_offset} bytes\n"
            f"{resume_lines}\n"
            f"  getter (long-lived): {get_name or 'not found'}"
        )
    else:
        print(
            "Fiber uprobe not attached — per-thread fiber names will be unavailable.\n"
            "  Run with --verbose for details, or pass --fiber-name-offset N."
        )

    print(f"Sampling PID {pid} at {args.freq} Hz for {args.duration}s ...")

    try:
        while True:
            data = collect(b, pid, args.duration, debug_bpf=args.debug_bpf)
            render(data, pid, args.duration, args.freq, args.lines, has_uprobe)
            if args.debug_bpf:
                print(f"\n[bpf] probes attached: {has_uprobe}  ({len(resume_syms)} resume(s), getter={'yes' if get_addr else 'no'})")
                for addr, name in resume_syms:
                    print(f"  resume  0x{addr:x}  {name}")
                if get_addr:
                    print(f"  getter  0x{get_addr:x}  {get_name}")
                if data.get("debug"):
                    d = data["debug"]
                    print(f"[bpf] uprobe_hits: resume={d['hits_resume']}  getter={d['hits_getter']}")
                    if d["tid_fiber"]:
                        print(f"[bpf] tid_to_fiber ({len(d['tid_fiber'])} entries):")
                        for tid, name in sorted(d["tid_fiber"].items()):
                            print(f"  TID {tid:6d}  name={name!r}")
                    else:
                        print("[bpf] tid_to_fiber: empty — uprobes not firing or fiber pointers invalid")
            if not args.watch:
                break
    except KeyboardInterrupt:
        print("\nDetaching.")


def main():
    parser = argparse.ArgumentParser(
        prog="lavinmq-diagnostics",
        description="Diagnostics tools for LavinMQ",
    )
    subparsers = parser.add_subparsers(dest="command", metavar="COMMAND")
    subparsers.required = True

    top = subparsers.add_parser(
        "top",
        help="show CPU hot functions using BPF stack sampling",
    )
    top.add_argument("--pid", type=int, default=None, metavar="PID",
                     help="target PID (default: auto-detect)")
    top.add_argument("--pidfile", metavar="PATH",
                     default="/var/run/lavinmq/lavinmq.pid",
                     help="path to LavinMQ pidfile")
    top.add_argument("--duration", type=int, default=5, metavar="SECS",
                     help="sampling window in seconds (default: 5)")
    top.add_argument("--freq", type=int, default=99, metavar="HZ",
                     help="sampling frequency in Hz (default: 99)")
    top.add_argument("--lines", type=int, default=20, metavar="N",
                     help="top entries per section (default: 20)")
    top.add_argument("--watch", action="store_true",
                     help="re-sample continuously until Ctrl+C")
    top.add_argument("--fiber-name-offset", type=int, default=None, metavar="N",
                     help="byte offset of @name in Crystal::Fiber (auto-detected from DWARF)")
    top.add_argument("--verbose", "-v", action="store_true",
                     help="print diagnostic info: binary path, symbol lookup results, DWARF offsets")
    top.add_argument("--debug-bpf", action="store_true",
                     help="after each sample window, print uprobe hit counts and tid_to_fiber contents")

    args = parser.parse_args()
    if args.command == "top":
        cmd_top(args)


if __name__ == "__main__":
    main()
