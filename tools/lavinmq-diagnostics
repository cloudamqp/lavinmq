#!/usr/bin/env python3
"""
lavinmq-diagnostics top — CPU hot functions for LavinMQ

Per sample the BPF program captures:
  • user-space call stack  (what Crystal code was on CPU)
  • kernel call stack      (which syscall was in flight, if any)
  • TID                    (which OS thread / fiber scheduler thread)
  • CPU core index
  • comm                   (OS thread name, e.g. "Worker #0")

Additionally, the script fetches LavinMQ's /api/diagnostics/fibers endpoint
to list live fibers by name, which reveals which queues, exchanges, shovels
and connections are active at sample time.

Requires: python3-bpfcc (Debian/Ubuntu) or bcc-tools (RHEL/Fedora)
          CAP_BPF + CAP_PERFMON, or kernel.perf_event_paranoid <= 1
          LavinMQ built with debug info for readable symbol names
"""

import argparse
import http.client
import json
import os
import socket
import subprocess
import sys
import time
from collections import defaultdict

try:
    from bcc import BPF, PerfType, PerfSWConfig
except ImportError:
    sys.exit(
        "Error: python3-bpfcc is not installed.\n"
        "  Debian/Ubuntu: apt install python3-bpfcc\n"
        "  RHEL/Fedora:   dnf install bcc-tools"
    )

# Each sample records: pid, tid, cpu, both stack IDs, and the OS thread name.
# The comm field (16 bytes) holds the kernel thread name at sample time —
# currently Crystal worker threads are named "Worker #N", but if Crystal or
# LavinMQ propagates fiber names to the OS thread via prctl, this becomes
# a direct queue/connection identifier at zero cost.
BPF_PROGRAM = r"""
#include <uapi/linux/ptrace.h>

struct key_t {
    u32 pid;
    u32 tid;
    u32 cpu;
    int user_stack_id;
    int kernel_stack_id;
    char comm[TASK_COMM_LEN];  /* OS thread name, max 16 bytes */
};

BPF_STACK_TRACE(user_stacks,    16384);
BPF_STACK_TRACE(kernel_stacks,   8192);
BPF_HASH(counts, struct key_t, u64, 16384);

int sample_stack(struct bpf_perf_event_data *ctx) {
    u64 id  = bpf_get_current_pid_tgid();
    u32 pid = id >> 32;
    u32 tid = (u32)id;

    if (TARGET_PID && pid != (u32)TARGET_PID)
        return 0;

    struct key_t key = {};
    key.pid             = pid;
    key.tid             = tid;
    key.cpu             = bpf_get_smp_processor_id();
    key.user_stack_id   = user_stacks.get_stackid(ctx,   BPF_F_USER_STACK | BPF_F_REUSE_STACKID);
    key.kernel_stack_id = kernel_stacks.get_stackid(ctx, BPF_F_REUSE_STACKID);
    bpf_get_current_comm(&key.comm, sizeof(key.comm));

    counts.increment(key);
    return 0;
}
"""

BOLD  = "\033[1m"
RESET = "\033[0m"
DIM   = "\033[2m"
CYAN  = "\033[36m"

FIBER_CATEGORIES = [
    ("Queue consumers",    lambda n: n.startswith("Consumer vhost=")),
    ("Queue maintenance",  lambda n: n.startswith("Queue#")),
    ("Connections",        lambda n: n.startswith("AMQP") or n.startswith("MQTT")),
    ("Shovels",            lambda n: n.startswith("Shovel")),
    ("Federation",         lambda n: n.startswith("Federation")),
]


def trunc(s, n):
    return s if len(s) <= n else s[:n - 3] + "..."


def bar(pct, width=20):
    return "█" * int(pct / 100 * width)


def section(title):
    pad = "─" * max(0, 74 - len(title))
    print(f"\n{BOLD}{CYAN}── {title} {pad}{RESET}")


def find_pid(args):
    if args.pid:
        return args.pid

    if args.pidfile and os.path.exists(args.pidfile):
        try:
            return int(open(args.pidfile).read().strip())
        except (ValueError, OSError):
            pass

    try:
        out = subprocess.check_output(["pgrep", "-x", "lavinmq"], stderr=subprocess.DEVNULL)
        pids = out.decode().strip().split()
        if len(pids) == 1:
            return int(pids[0])
        if len(pids) > 1:
            sys.exit(
                f"Error: multiple lavinmq processes found: {', '.join(pids)}\n"
                "Use --pid to specify which one."
            )
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    sys.exit(
        "Error: lavinmq process not found.\n"
        "Is it running? Use --pid PID or --pidfile PATH to specify."
    )


def check_permissions():
    if os.geteuid() == 0:
        return
    try:
        paranoid = int(open("/proc/sys/kernel/perf_event_paranoid").read().strip())
    except (OSError, ValueError):
        sys.exit("Error: cannot read perf_event_paranoid. Run as root or grant CAP_BPF + CAP_PERFMON.")
    if paranoid > 1:
        sys.exit(
            f"Error: kernel.perf_event_paranoid={paranoid} (must be <= 1 for unprivileged BPF profiling).\n"
            "Fix:  sudo sysctl -w kernel.perf_event_paranoid=1\n"
            "  or: run lavinmq-diagnostics as root."
        )


INTERNAL_UNIX_SOCKET = "/tmp/lavinmqctl.sock"


class _UnixSocketHTTPConnection(http.client.HTTPConnection):
    """HTTP connection over a UNIX domain socket (no auth required)."""
    def __init__(self, socket_path):
        super().__init__("localhost")
        self._socket_path = socket_path

    def connect(self):
        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.settimeout(self.timeout)
        self.sock.connect(self._socket_path)


def fetch_fibers():
    """Fetch live fiber list via the internal UNIX socket (no auth required)."""
    if not os.path.exists(INTERNAL_UNIX_SOCKET):
        return None
    try:
        conn = _UnixSocketHTTPConnection(INTERNAL_UNIX_SOCKET)
        conn.request("GET", "/api/diagnostics/fibers")
        resp = conn.getresponse()
        if resp.status == 200:
            return json.loads(resp.read())
    except OSError:
        pass
    return None


def resolve_user_sym(b, addr, pid):
    raw = b.sym(addr, pid, show_module=False, show_offset=False)
    return raw.decode("utf-8", errors="replace").lstrip("*")


def resolve_ksym(b, addr):
    raw = b.ksym(addr, show_module=False, show_offset=False)
    return raw.decode("utf-8", errors="replace")


def collect(b, pid, duration):
    b["counts"].clear()
    b["user_stacks"].clear()
    b["kernel_stacks"].clear()

    deadline = time.monotonic() + duration
    while time.monotonic() < deadline:
        if not os.path.exists(f"/proc/{pid}"):
            sys.exit(f"\nProcess {pid} exited during sampling.")
        time.sleep(0.5)

    user_sym_counts   = defaultdict(int)
    kernel_sym_counts = defaultdict(int)
    # tid → {"total": int, "syms": {sym: n}, "cpus": {cpu: n}, "comm": str}
    thread_info = defaultdict(lambda: {"total": 0, "syms": defaultdict(int),
                                       "cpus": defaultdict(int), "comm": ""})

    for key, count in b["counts"].items():
        n = count.value

        user_sym = "[unknown]"
        if key.user_stack_id >= 0:
            frames = list(b["user_stacks"].walk(key.user_stack_id))
            if frames:
                user_sym = resolve_user_sym(b, frames[0], pid)
        user_sym_counts[user_sym] += n

        if key.kernel_stack_id >= 0:
            frames = list(b["kernel_stacks"].walk(key.kernel_stack_id))
            if frames:
                kernel_sym_counts[resolve_ksym(b, frames[0])] += n

        t = thread_info[key.tid]
        t["total"] += n
        t["syms"][user_sym] += n
        t["cpus"][key.cpu] += n
        if not t["comm"]:
            t["comm"] = key.comm.decode("utf-8", errors="replace").rstrip("\x00")

    return {
        "user":    user_sym_counts,
        "kernel":  kernel_sym_counts,
        "threads": thread_info,
    }


def render(data, fibers, pid, duration, freq, lines):
    total = sum(data["user"].values()) or 1
    has_unknown = False

    print("\033[H\033[2J", end="")
    print(
        f"{BOLD}LavinMQ CPU Hot Functions{RESET}"
        f" — PID {pid}"
        f" — {duration}s @ {freq}Hz"
        f" — {total:,} samples"
    )

    # ── User-space hot functions ──────────────────────────────────────────────
    section("User-Space Hot Functions")
    print(f"  {'Rank':>4}  {'Function':<52}  {'Samples':>8}  {'CPU%':>5}  Bar")
    print("  " + "─" * 82)
    for i, (sym, count) in enumerate(
        sorted(data["user"].items(), key=lambda x: x[1], reverse=True)[:lines], 1
    ):
        pct = count / total * 100
        if sym == "[unknown]":
            has_unknown = True
        print(f"  {i:>4}  {trunc(sym, 52):<52}  {count:>8,}  {pct:>4.1f}%  {bar(pct)}")

    # ── Per-thread breakdown ──────────────────────────────────────────────────
    section("Per-Thread Breakdown")
    print(f"  {'TID':>8}  {'Thread':<12}  {'Samples':>8}  {'CPU%':>5}  {'CPUs':>6}  {'Top Function':<38}")
    print("  " + "─" * 90)
    for tid, info in sorted(data["threads"].items(), key=lambda x: x[1]["total"], reverse=True)[:lines]:
        pct      = info["total"] / total * 100
        top_sym  = max(info["syms"], key=info["syms"].get)
        cpu_list = ",".join(str(c) for c in sorted(info["cpus"]))
        comm     = info["comm"] or "?"
        print(
            f"  {tid:>8}  {trunc(comm, 12):<12}  {info['total']:>8,}  {pct:>4.1f}%"
            f"  {cpu_list:>6}  {trunc(top_sym, 38):<38}"
        )

    # ── Kernel hot functions ──────────────────────────────────────────────────
    section("Kernel Hot Functions  (samples caught inside a syscall)")
    if data["kernel"]:
        ksyms_total = sum(data["kernel"].values())
        pct_in_kernel = ksyms_total / total * 100
        print(f"  {ksyms_total:,} of {total:,} samples ({pct_in_kernel:.1f}%) were inside a syscall\n")
        print(f"  {'Rank':>4}  {'Kernel Function':<52}  {'Samples':>8}  {'CPU%':>5}  Bar")
        print("  " + "─" * 82)
        for i, (sym, count) in enumerate(
            sorted(data["kernel"].items(), key=lambda x: x[1], reverse=True)[:lines], 1
        ):
            pct = count / total * 100
            print(f"  {i:>4}  {trunc(sym, 52):<52}  {count:>8,}  {pct:>4.1f}%  {bar(pct)}")
    else:
        print(f"  {DIM}No kernel stack samples — all CPU time was in user space.{RESET}")

    # ── Active LavinMQ fibers ─────────────────────────────────────────────────
    section("Active LavinMQ Fibers")
    if fibers is None:
        print(f"  {DIM}Unavailable — {INTERNAL_UNIX_SOCKET} not found or not responding.{RESET}")
        print(f"  {DIM}Is LavinMQ running on this host?{RESET}")
    else:
        names = [f["name"] for f in fibers]
        printed = set()
        for label, predicate in FIBER_CATEGORIES:
            matches = [n for n in names if predicate(n)]
            if not matches:
                continue
            print(f"\n  {BOLD}{label} ({len(matches)}){RESET}")
            for name in sorted(matches)[:lines]:
                print(f"    {name}")
                printed.add(name)
        other = [n for n in names if n not in printed]
        if other:
            print(f"\n  {BOLD}Other ({len(other)}){RESET}")
            for name in sorted(other)[:lines]:
                print(f"    {name}")

    print(f"\n  {DIM}{time.strftime('%Y-%m-%d %H:%M:%S')}  |  Ctrl+C to exit{RESET}", end="")
    if has_unknown:
        print(
            f"\n\n  {DIM}Note: '[unknown]' symbols — rebuild with debug info:\n"
            f"  make bin/lavinmq CRYSTAL_FLAGS=--debug{RESET}",
            end="",
        )
    print()


def cmd_top(args):
    check_permissions()
    pid = find_pid(args)

    if not os.path.exists(f"/proc/{pid}"):
        sys.exit(f"Error: no process with PID {pid}.")

    prog = BPF_PROGRAM.replace("TARGET_PID", str(pid))
    b = BPF(text=prog)
    b.attach_perf_event(
        ev_type=PerfType.SOFTWARE,
        ev_config=PerfSWConfig.CPU_CLOCK,
        fn_name="sample_stack",
        sample_freq=args.freq,
    )

    print(f"Sampling PID {pid} at {args.freq} Hz for {args.duration}s ...")

    try:
        while True:
            fibers = fetch_fibers()
            data = collect(b, pid, args.duration)
            render(data, fibers, pid, args.duration, args.freq, args.lines)
            if not args.watch:
                break
    except KeyboardInterrupt:
        print("\nDetaching.")


def main():
    parser = argparse.ArgumentParser(
        prog="lavinmq-diagnostics",
        description="Diagnostics tools for LavinMQ",
    )
    subparsers = parser.add_subparsers(dest="command", metavar="COMMAND")
    subparsers.required = True

    top = subparsers.add_parser(
        "top",
        help="show CPU hot functions using BPF stack sampling",
    )
    top.add_argument(
        "--pid", type=int, default=None, metavar="PID",
        help="target PID (default: auto-detect via pgrep or pidfile)",
    )
    top.add_argument(
        "--pidfile", metavar="PATH",
        default="/var/run/lavinmq/lavinmq.pid",
        help="path to LavinMQ pidfile (default: /var/run/lavinmq/lavinmq.pid)",
    )
    top.add_argument(
        "--duration", type=int, default=5, metavar="SECS",
        help="sampling window in seconds (default: 5)",
    )
    top.add_argument(
        "--freq", type=int, default=99, metavar="HZ",
        help="sampling frequency in Hz (default: 99)",
    )
    top.add_argument(
        "--lines", type=int, default=20, metavar="N",
        help="number of top entries to display per section (default: 20)",
    )
    top.add_argument(
        "--watch", action="store_true",
        help="re-sample continuously until Ctrl+C",
    )
    args = parser.parse_args()
    if args.command == "top":
        cmd_top(args)


if __name__ == "__main__":
    main()
